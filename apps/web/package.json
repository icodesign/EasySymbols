{
  "name": "@easysymbols/web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "vite build",
    "deploy": "bun run build && wrangler deploy --env=\"\"",
    "start": "vite preview --host 0.0.0.0 --port 3000",
    "test": "bun run build && bun test tests/rendered-html.test.mjs",
    "test:rendered": "bun test tests/rendered-html.test.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .vite --ignore-pattern .tanstack"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@easysymbols/core": "workspace:*",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-router": "1.170.17",
    "fflate": "^0.8.2",
    "pathkit-wasm": "1.0.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tanstack-router-ga4": "^1.6.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@tailwindcss/vite": "4.2.1",
    "@tanstack/router-plugin": "1.168.19",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "9.39.4",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.0.13",
    "wrangler": "4.110.0"
  },
  "type": "module"
}
