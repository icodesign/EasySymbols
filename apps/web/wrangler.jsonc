{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "easysymbols-web",
  "compatibility_date": "2026-07-13",
  "routes": [
    {
      "pattern": "easysymbols.rootstudio.io",
      "custom_domain": true,
    },
  ],
  "env": {
    "preview": {
      "routes": [],
    },
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
  },
  "observability": {
    "enabled": true,
  },
}
